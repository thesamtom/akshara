# Copy this file to .env and place newly generated API keys there.
# Never commit .env or paste real keys into source files or chat.
GEMINI_API_KEY=replace-with-your-gemini-api-key
SARVAM_STT_API_KEY=replace-with-new-speech-to-text-key
SARVAM_TTS_API_KEY=replace-with-new-text-to-speech-key
OPENAI_API_KEY=replace-with-your-openai-api-key


# Optional: Supabase Caching Configuration for Malayalam Word Definitions.
# If these are unconfigured, lookups will cache in a local sqlite database (cache.db) automatically.
SUPABASE_URL=replace-with-your-supabase-project-url
SUPABASE_KEY=replace-with-your-supabase-anon-key
